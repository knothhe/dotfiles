# source
source_file() {
    local file="$1"
    if [[ -f "$file" ]]; then
        source "$file"
    fi
}

source_file "$HOME/.config/xshrc/envs"
source_file "$HOME/.config/xshrc/alias"
source_file "$HOME/.config/xshrc/functions"
source_file "$HOME/.config/xshrc/keybindings"
source_file "$HOME/.config/xshrc/proxy"
source_file "$HOME/.config/xshrc/tmpl"

# OS-specific configuration
if [[ "$OSTYPE" == "darwin"* ]]; then
    # macOS (Darwin)
    for f in "$HOME/.config/xshrc/darwin"/*; do
        source_file "$f"
    done
elif [[ "$OSTYPE" == "linux-gnu"* ]]; then
    # Linux
    source_file "$HOME/.config/xshrc/linux"
fi

